# API key for OpenAI or any OpenAI-compatible provider (e.g. DeepSeek)
OPENAI_API_KEY=sk-...

# Optional: override the API base URL for alternative providers
# DeepSeek: https://api.deepseek.com/v1
OPENAI_BASE_URL=

# Optional: override the model name (default: gpt-4o-mini)
# DeepSeek: deepseek-chat
OPENAI_MODEL=
